# --- CONFIGURACION GENERAL ---
# Entorno de despliegue (development o production)
FLASK_ENV=development

# Clave secreta para JWT o sesiones (Obligatorio en producción)
SECRET_KEY=tu_clave_secreta_super_segura

# --- PAGOS Y PASARELAS (STRIPE) ---
# Llave privada de la API de Stripe (sk_live_... o sk_test_...)
STRIPE_API_KEY=tu_clave_stripe_aqui

# Secreto del Webhook de Stripe (whsec_...) - Vital para que el pago active la cocina
STRIPE_WEBHOOK_SECRET=tu_secreto_webhook_stripe

# --- INTEGRACION WHATSAPP (WAHA API) ---
# URL de la instancia de WAHA donde se enviarán las peticiones (Local o VPS)
WAHA_URL=http://113.30.148.104:3000

# Nombre de la sesión configurada en WAHA
WAHA_SESSION=carbones

# API Key configurada en WAHA (Header X-Api-Key) para asegurar los endpoints de tu instancia
WAHA_HTTP_API_KEY=1060705b0a574d1fbc92fa10a2b5aca7

# --- INTELIGENCIA ARTIFICIAL (GEMINI) ---
# Clave de API para el Agente AI que lee WhatsApp
GEMINI_API_KEY=tu_gemini_api_key_aqui
