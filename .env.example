# ⚙️ CONFIGURACIÓN ENTERPRISE - CARBONES Y POLLOS TPV
# Copia este archivo a .env y completa los valores según tu entorno.

# --- Identidad del Sistema ---
APP_NAME="Carbones y Pollos TPV Enterprise"
APP_VERSION="2.6.0"
ENVIRONMENT="production" # production | development
DEBUG=False

# --- Base de Datos ---
# Local: sqlite:///./tpv_data.sqlite
# Render/Cloud: sqlite:////data/tpv_data.sqlite
DATABASE_URL="sqlite:///./tpv_data.sqlite"

# --- Seguridad ---
SECRET_KEY="tu_clave_secreta_super_segura_aqui"
CORS_ORIGINS=["*"] # Cambiar por el dominio del VPS en producción

# --- Inteligencia Artificial (Google Gemini) ---
GOOGLE_API_KEY="AIzaSy..." # Tu API Key de Google AI Studio

# --- Infraestructura de Red ---
VPS_URL="http://tu-vps-ip:8000"
LOCAL_PRINTER_URL="http://127.0.0.1:8080/webhook/imprimir"

# --- Operaciones ---
AUTO_Z_CLOSE_TIME="03:00"
MAX_LOG_AGE_DAYS=30
SYNC_INTERVAL=10
