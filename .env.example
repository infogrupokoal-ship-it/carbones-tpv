# ==============================================================================
# 🚀 CARBONES Y POLLOS TPV - ENTERPRISE ENVIRONMENT VARIABLES
# ==============================================================================

# --- CONFIGURACION GENERAL DEL SISTEMA ---
# Entorno de despliegue (development, staging, production)
FLASK_ENV=production
# Si es true, el sistema habilitará rutas Swagger/Docs y modo debug
DEBUG=False

# Clave secreta para JWT o sesiones (Obligatorio en producción). ¡No la compartas!
SECRET_KEY=tu_clave_secreta_super_segura_de_produccion_generar_con_uuid

# --- BASE DE DATOS ---
# URL de la base de datos local
DATABASE_URL=sqlite:///instance/gestion_avisos.sqlite

# --- TELEMETRIA Y LOGS ---
# Nivel de logs: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Retención de logs en días
LOG_RETENTION_DAYS=30

# --- PAGOS Y PASARELAS (STRIPE) ---
# Llave pública y privada de la API de Stripe
STRIPE_PUBLIC_KEY=pk_live_tu_clave_publica
STRIPE_API_KEY=sk_live_tu_clave_privada
# Secreto del Webhook de Stripe (whsec_...) - Vital para que el pago active la cocina
STRIPE_WEBHOOK_SECRET=whsec_tu_secreto_webhook_stripe

# --- INTEGRACION WHATSAPP (WAHA API) ---
# URL de la instancia de WAHA donde se enviarán las peticiones (Local o VPS)
WAHA_URL=http://127.0.0.1:3000
# Nombre de la sesión configurada en WAHA
WAHA_SESSION=carbones
# API Key configurada en WAHA (Header X-Api-Key) para asegurar los endpoints de tu instancia
WAHA_HTTP_API_KEY=tu_api_key_de_waha_aqui

# --- INTELIGENCIA ARTIFICIAL (GEMINI / GOOGLE) ---
# Clave de API para el Agente AI que lee WhatsApp y da métricas
GEMINI_API_KEY=tu_gemini_api_key_aqui

# --- EDGE COMPUTING (HARDWARE BRIDGE) ---
# URL donde el Hardware Bridge (impresoras/cajón) está escuchando localmente
HARDWARE_BRIDGE_URL=http://127.0.0.1:8080

# --- CÓDIGOS PIN DE SEGURIDAD ---
# Pin por defecto de administrador en caso de emergencia
ADMIN_RECOVERY_PIN=1234
